{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Product in the inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "barcode": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "isPopular": { "type": "boolean" },
        "stock": { "type": "number" }
      },
      "required": ["id", "name", "price", "category", "image", "description", "stock"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier of products",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "address", "phone", "email", "description"]
    },
    "AppUser": {
      "title": "AppUser",
      "description": "System user with credentials and role",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "username", "password", "role", "createdAt"]
    },
    "LoginLog": {
      "title": "LoginLog",
      "description": "History of users logging in",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "timestamp": { "type": "string" },
        "device": { "type": "string" }
      },
      "required": ["id", "userId", "username", "timestamp", "device"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Record of transaction sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "userId", "username", "items", "total", "paymentMethod", "timestamp"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products in the store"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Collection of suppliers"
    },
    "/users/{userId}": {
      "schema": "AppUser",
      "description": "Collection of system users"
    },
    "/logs/{logId}": {
      "schema": "LoginLog",
      "description": "Logs of user login events"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales history logs"
    }
  }
}
